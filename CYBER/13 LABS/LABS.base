views:
  - type: cards
    name: HTB
    filters:
      and:
        - file.folder == "CYBER/13 LABS/HTB"
    order:
      - file.name
      - pawned
      - file.tags
      - description
    sort:
      - property: file.ctime
        direction: DESC
    image: note.image
    cardSize: 190
    imageAspectRatio: 1
  - type: cards
    name: THM
    filters:
      and:
        - file.inFolder("CYBER/13 LABS/THM")
    image: note.image
